{
    "name": "@guru-fund/cli",
    "version": "0.1.0",
    "description": "JSON-first agent CLI for Guru Protocol fund operations.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "guru": "./dist/index.js"
    },
    "files": [
        "dist",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && node scripts/fix-esm-imports.mjs dist",
        "clean": "rm -rf dist .turbo tsconfig.build.tsbuildinfo",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "prepack": "pnpm run build"
    },
    "dependencies": {
        "@guru-fund/sdk": "^0.1.0",
        "@tenderly/sdk": "^0.3.1",
        "ethers": "=6.15.0"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@typescript-eslint/eslint-plugin": "^7.8.0",
        "@typescript-eslint/parser": "^8.8.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "typescript": "5.9.2"
    }
}
